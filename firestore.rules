
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- COLLECTIONS ---

    // USERS
    match /users/{uid} {
      // Allow get for anyone to validate referrers by name
      allow get: if true;
      // Allow the owner to read (get/list) their full profile
      allow read: if isOwner(uid);
      
      allow create: if isOwner(uid) 
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.username.matches('^[a-z0-9_]{3,20}$')
        && request.resource.data.phone.matches('^(07|08|09)[0-9]{9}$')
        && request.resource.data.referralCode.matches('^GETR-[A-Z0-9]{8}$')
        && request.resource.data.accountStatus == 'pending'
        && request.resource.data.isActive == false;
      
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['bankAccount', 'accountStatus', 'isActive', 'updatedAt', 'lastLoginAt', 'earningWallet', 'mainWallet', 'referralCountCycle', 'totalReferrals', 'weeklyReferrals']);
      
      // Notifications Subcollection
      // Explicitly splitting read into get and list for better rule evaluation
      match /notifications/{id} {
        allow get, list, update: if isOwner(uid);
      }

      // Transactions Subcollection
      match /transactions/{id} {
        allow get, list: if isOwner(uid);
      }
    }

    // USERNAMES LOOKUP
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // EMAILS LOOKUP
    match /emails/{email} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // REFERRAL CODES LOOKUP
    match /referralCodes/{code} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // PREVENT OTHER WRITES
    match /{path=**} {
      allow read, write: if false;
    }
    
    // Deployment trigger: Updated subcollection permissions for better evaluation.
  }
}
