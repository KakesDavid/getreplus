
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "The core user profile for GetrePlus members.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "fullName": {
          "type": "string"
        },
        "username": {
          "type": "string",
          "pattern": "^[a-z0-9_]{3,20}$"
        },
        "phone": {
          "type": "string",
          "pattern": "^(07|08|09)[0-9]{9}$"
        },
        "referralCode": {
          "type": "string",
          "pattern": "^GETR-[A-Z0-9]{8}$"
        },
        "referredBy": {
          "type": [
            "string",
            "null"
          ]
        },
        "bankAccount": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "bankName": {
              "type": "string"
            },
            "bankCode": {
              "type": "string"
            },
            "accountNumber": {
              "type": "string"
            },
            "accountName": {
              "type": "string"
            },
            "verifiedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "accountStatus": {
          "type": "string",
          "enum": [
            "pending",
            "active"
          ]
        },
        "isActive": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastLoginAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "signupIp": {
          "type": [
            "string",
            "null"
          ]
        },
        "deviceFingerprint": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "uid",
        "email",
        "fullName",
        "username",
        "phone",
        "referralCode",
        "accountStatus",
        "isActive",
        "createdAt",
        "updatedAt"
      ]
    },
    "UsernameLookup": {
      "title": "UsernameLookup",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ReferralCodeLookup": {
      "title": "ReferralCodeLookup",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{uid}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Primary user profiles. Document ID matches Auth UID.",
          "params": [
            {
              "name": "uid",
              "description": "Auth UID"
            }
          ]
        }
      },
      {
        "path": "/usernames/{username}",
        "definition": {
          "entityName": "UsernameLookup",
          "schema": {
            "$ref": "#/backend/entities/UsernameLookup"
          },
          "description": "Lookup table for unique usernames.",
          "params": [
            {
              "name": "username",
              "description": "The unique username"
            }
          ]
        }
      },
      {
        "path": "/referralCodes/{code}",
        "definition": {
          "entityName": "ReferralCodeLookup",
          "schema": {
            "$ref": "#/backend/entities/ReferralCodeLookup"
          },
          "description": "Lookup table for unique referral codes.",
          "params": [
            {
              "name": "code",
              "description": "The unique referral code"
            }
          ]
        }
      }
    ]
  }
}
